  "homepage": "https://github.com/boazk1/reminders-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/boazk1/reminders-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/boazk1/reminders-mcp/issues"
  },
  "bin": {
